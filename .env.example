# Copy this file to .env and fill in real values before running docker compose.
# Only used by the control-bot service (docker-compose.yml) — the main
# neuraself service doesn't read any of this.

# Bot token of a REAL Discord Application (Developer Portal > Bot > Reset Token),
# invited to your server with the `applications.commands` + `bot` scopes.
# This is NOT one of your self-bot farming account tokens.
CONTROL_BOT_TOKEN=

# Who can /pause and /start which account is controlled entirely by each
# account's "dc_user_id" in config/accounts.json — set that field to the Discord
# user ID of the one person allowed to manage that account.
